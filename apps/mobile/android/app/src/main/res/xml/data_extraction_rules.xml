<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup / transfer rules (API 31+). Conservative "exclude everything"
    ruleset: token prefs and secure storage must never leave the device via
    cloud backup or device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>

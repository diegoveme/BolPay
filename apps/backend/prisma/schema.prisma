// BolPay relational data model (off-chain state).
// Mirrors docs/data-model.md. On-chain references (escrow id, stellar hash) are
// stored alongside the entities they relate to. Enum values match @bolpay/shared.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase: pooled connection (PgBouncer, port 6543) for the app.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by Prisma Migrate / introspection.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enumerations (docs/data-model.md §4)
// ---------------------------------------------------------------------------

enum UserRole {
  company
  freelancer
  fixed_employee
  administrator
}

enum UserStatus {
  active
  suspended
}

enum AuthProvider {
  google
  github
  discord
  email
  wallet
}

enum ContractStatus {
  draft
  pending_acceptance
  changes_requested
  accepted
  active
  completed
  rejected
}

enum MilestoneStatus {
  pending
  submitted
  in_review
  approved
  released
  disputed
}

enum DeliverableStatus {
  submitted
  changes_requested
  approved
}

enum EscrowType {
  contract
  payroll
}

enum EscrowStatus {
  created
  funded
  releasing
  released
  disputed
  closed
}

enum DisputeStatus {
  open
  under_review
  // deprecated: disputes are resolved mutually by the parties, with no admin
  // escalation. Value retained for migration safety; no code sets it.
  escalated
  resolved
  closed
}

enum DisputeOutcome {
  release_to_freelancer
  refund_to_company
  split
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum PayrollFrequency {
  weekly
  biweekly
  monthly
}

enum PayrollStatus {
  draft
  funded
  active
  paused
  completed
}

enum PayrollExecutionStatus {
  pending
  succeeded
  failed
  partial
}

enum TransactionOperation {
  fund
  release
  refund
  payroll_distribution
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique
  name           String?
  role           UserRole
  // Account standing. Suspended accounts are blocked at login by AuthService.
  status         UserStatus   @default(active)
  authProvider   AuthProvider @map("auth_provider")
  // Stellar G-address of the Pollar-managed wallet. Required to operate
  // (a Stellar wallet connection is mandatory to use the platform).
  stellarAddress String?      @unique @map("stellar_address")
  // Pollar wallet id (wal_...) for server-side operations (activation, lookups).
  pollarWalletId String?      @unique @map("pollar_wallet_id")
  // Email ownership verified by BolPay via SMTP/Nodemailer (Pollar does not
  // expose a backend-verifiable email claim). Gates sensitive actions.
  emailVerified  Boolean      @default(false) @map("email_verified")
  createdAt      DateTime     @default(now()) @map("created_at")

  companyProfile         CompanyProfile?
  freelancerProfile      FreelancerProfile?
  emailVerificationTokens EmailVerificationToken[]
  wallets                Wallet[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  disputesOpened    Dispute[]          @relation("DisputeOpenedBy")
  disputesProposed  Dispute[]          @relation("DisputeProposedBy")
  disputesResolved  Dispute[]          @relation("DisputeResolvedBy")
  evidenceSubmitted DisputeEvidence[]  @relation("EvidenceSubmittedBy")
  deliverables      Deliverable[]      @relation("DeliverableSubmittedBy")
  invitationsSent   Invitation[]       @relation("InvitationInvitedBy")
  payrollItems      PayrollItem[]

  @@map("users")
}

model Wallet {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String  @map("user_id") @db.Uuid
  stellarAddress String  @map("stellar_address")
  isPrimary      Boolean @default(false) @map("is_primary")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stellarAddress])
  @@index([userId])
  @@map("wallets")
}

model CompanyProfile {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @unique @map("user_id") @db.Uuid
  name        String
  description String?
  location    String?
  website     String?
  industry    String?
  values      String?
  avatarUrl   String? @map("avatar_url")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts Contract[]
  payrolls  Payroll[]

  @@map("company_profiles")
}

model FreelancerProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String   @map("display_name")
  headline    String?
  bio         String?
  skills      String[] @default([])
  location    String?
  website     String?
  linkedin    String?
  github      String?
  avatarUrl   String?  @map("avatar_url")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@map("freelancer_profiles")
}

// Single-use, expiring token emailed (via SMTP/Nodemailer) to confirm email ownership.
model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Short-lived numeric code emailed to prove ownership of an email address on
// the manual (self-declared wallet) sign-in path, before /auth/login. Not tied
// to a user: it gates the login by email, so it may exist before the account
// does. One active code per email (the row is replaced on each request and
// deleted once consumed).
model EmailLoginCode {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  codeHash  String   @map("code_hash")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_login_codes")
}

// Email invitations.
model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  email       String
  role        UserRole
  token       String           @unique
  status      InvitationStatus @default(pending)
  invitedById String           @map("invited_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  expiresAt   DateTime         @map("expires_at")

  invitedBy User @relation("InvitationInvitedBy", fields: [invitedById], references: [id])

  @@index([email])
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// Contracts & milestones
// ---------------------------------------------------------------------------

model Contract {
  id           String         @id @default(uuid()) @db.Uuid
  companyId    String         @map("company_id") @db.Uuid
  freelancerId String         @map("freelancer_id") @db.Uuid
  title        String
  description  String?
  totalAmount  Decimal        @map("total_amount") @db.Decimal(20, 7)
  status       ContractStatus @default(draft)
  // Freelancer feedback when requesting changes or rejecting.
  reviewNote   String?        @map("review_note")
  deadline     DateTime?      @db.Date
  acceptedAt   DateTime?      @map("accepted_at")
  completedAt  DateTime?      @map("completed_at")
  escrowId     String?        @unique @map("escrow_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")

  company    CompanyProfile    @relation(fields: [companyId], references: [id])
  freelancer FreelancerProfile @relation(fields: [freelancerId], references: [id])
  escrow     Escrow?           @relation(fields: [escrowId], references: [id])
  milestones Milestone[]

  @@index([companyId])
  @@index([freelancerId])
  @@map("contracts")
}

model Milestone {
  id          String          @id @default(uuid()) @db.Uuid
  contractId  String          @map("contract_id") @db.Uuid
  // 0-based position; matches the Trustless Work milestone index on-chain.
  position    Int             @default(0)
  title       String
  description String?
  amount      Decimal         @db.Decimal(20, 7)
  deadline    DateTime?       @db.Date
  status      MilestoneStatus @default(pending)

  contract     Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  deliverables Deliverable[]
  disputes     Dispute[]
  transactions Transaction[]

  @@unique([contractId, position])
  @@index([contractId])
  @@map("milestones")
}

model Deliverable {
  id            String            @id @default(uuid()) @db.Uuid
  milestoneId   String            @map("milestone_id") @db.Uuid
  submittedById String            @map("submitted_by") @db.Uuid
  fileUrl       String?           @map("file_url")
  linkUrl       String?           @map("link_url")
  note          String?
  version       Int               @default(1)
  status        DeliverableStatus @default(submitted)
  // Company feedback when requesting changes.
  reviewNote    String?           @map("review_note")
  submittedAt   DateTime          @default(now()) @map("submitted_at")

  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  submittedBy User      @relation("DeliverableSubmittedBy", fields: [submittedById], references: [id])

  @@unique([milestoneId, version])
  @@index([milestoneId])
  @@map("deliverables")
}

// ---------------------------------------------------------------------------
// Escrow (Trustless Work reference) - funds a contract or a payroll
// ---------------------------------------------------------------------------

model Escrow {
  id              String       @id @default(uuid()) @db.Uuid
  // Soroban contract id of the Trustless Work escrow on Stellar.
  trustlessWorkId String?      @unique @map("trustless_work_id")
  type            EscrowType
  status          EscrowStatus @default(created)
  asset           String       @default("USDC")
  fundedAmount    Decimal?     @map("funded_amount") @db.Decimal(20, 7)
  releasedAmount  Decimal?     @map("released_amount") @db.Decimal(20, 7)
  createdAt       DateTime     @default(now()) @map("created_at")

  contract Contract?
  payroll  Payroll?

  @@map("escrows")
}

// ---------------------------------------------------------------------------
// Disputes
// ---------------------------------------------------------------------------

model Dispute {
  id               String          @id @default(uuid()) @db.Uuid
  milestoneId      String          @map("milestone_id") @db.Uuid
  openedById       String          @map("opened_by") @db.Uuid
  reason           String
  status           DisputeStatus   @default(open)
  // Standing resolution proposal: one party proposes a split, the OTHER party
  // must accept it (or counter-propose) before it executes on-chain. Cleared
  // meaning is "no proposal yet" when proposedById is null.
  proposalOutcome          DisputeOutcome? @map("proposal_outcome")
  proposalFreelancerAmount Decimal?        @map("proposal_freelancer_amount") @db.Decimal(20, 7)
  proposalCompanyAmount    Decimal?        @map("proposal_company_amount") @db.Decimal(20, 7)
  proposalNote             String?         @map("proposal_note")
  proposedById             String?         @map("proposed_by") @db.Uuid
  proposedAt               DateTime?       @map("proposed_at")
  // Final resolution (copied from the accepted proposal).
  outcome          DisputeOutcome?
  freelancerAmount Decimal?        @map("freelancer_amount") @db.Decimal(20, 7)
  companyAmount    Decimal?        @map("company_amount") @db.Decimal(20, 7)
  resolution       String?
  resolvedById     String?         @map("resolved_by") @db.Uuid
  openedAt         DateTime        @default(now()) @map("opened_at")
  resolvedAt       DateTime?       @map("resolved_at")

  milestone  Milestone         @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  openedBy   User              @relation("DisputeOpenedBy", fields: [openedById], references: [id])
  proposedBy User?             @relation("DisputeProposedBy", fields: [proposedById], references: [id])
  resolvedBy User?             @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])
  evidence   DisputeEvidence[]

  @@index([milestoneId])
  @@map("disputes")
}

model DisputeEvidence {
  id            String   @id @default(uuid()) @db.Uuid
  disputeId     String   @map("dispute_id") @db.Uuid
  submittedById String   @map("submitted_by") @db.Uuid
  fileUrl       String?  @map("file_url")
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  dispute     Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submittedBy User    @relation("EvidenceSubmittedBy", fields: [submittedById], references: [id])

  @@index([disputeId])
  @@map("dispute_evidence")
}

// ---------------------------------------------------------------------------
// Payroll
// ---------------------------------------------------------------------------

model Payroll {
  id        String           @id @default(uuid()) @db.Uuid
  companyId String           @map("company_id") @db.Uuid
  name      String
  frequency PayrollFrequency
  status    PayrollStatus    @default(draft)
  nextRun   DateTime?        @map("next_run")
  escrowId  String?          @unique @map("escrow_id") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")

  company    CompanyProfile     @relation(fields: [companyId], references: [id])
  escrow     Escrow?            @relation(fields: [escrowId], references: [id])
  items      PayrollItem[]
  executions PayrollExecution[]

  @@index([companyId])
  @@map("payrolls")
}

model PayrollItem {
  id               String  @id @default(uuid()) @db.Uuid
  payrollId        String  @map("payroll_id") @db.Uuid
  // Linked platform user (fixed employee) or null for an external wallet.
  recipientUserId  String? @map("recipient_user_id") @db.Uuid
  recipientAddress String  @map("recipient_address")
  recipientLabel   String? @map("recipient_label")
  amount           Decimal @db.Decimal(20, 7)

  payroll       Payroll       @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  recipientUser User?         @relation(fields: [recipientUserId], references: [id])
  transactions  Transaction[]

  @@index([payrollId])
  @@map("payroll_items")
}

model PayrollExecution {
  id          String                 @id @default(uuid()) @db.Uuid
  payrollId   String                 @map("payroll_id") @db.Uuid
  executedAt  DateTime               @default(now()) @map("executed_at")
  status      PayrollExecutionStatus @default(pending)
  totalAmount Decimal                @default(0) @map("total_amount") @db.Decimal(20, 7)

  payroll      Payroll       @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([payrollId])
  @@map("payroll_executions")
}

// ---------------------------------------------------------------------------
// On-chain settlement audit trail
// ---------------------------------------------------------------------------

model Transaction {
  id                 String               @id @default(uuid()) @db.Uuid
  stellarHash        String?              @unique @map("stellar_hash")
  operation          TransactionOperation
  amount             Decimal              @db.Decimal(20, 7)
  confirmedAt        DateTime?            @map("confirmed_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  milestoneId        String?              @map("milestone_id") @db.Uuid
  payrollItemId      String?              @map("payroll_item_id") @db.Uuid
  payrollExecutionId String?              @map("payroll_execution_id") @db.Uuid

  milestone        Milestone?        @relation(fields: [milestoneId], references: [id])
  payrollItem      PayrollItem?      @relation(fields: [payrollItemId], references: [id])
  payrollExecution PayrollExecution? @relation(fields: [payrollExecutionId], references: [id])

  @@index([milestoneId])
  @@index([payrollItemId])
  @@index([payrollExecutionId])
  @@map("transactions")
}

// ---------------------------------------------------------------------------
// Cross-cutting
// ---------------------------------------------------------------------------

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activity_logs")
}

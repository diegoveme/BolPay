# =============================================================================
# BolPay - root environment example. Copy per app to a local .env (never commit).
#   cp .env.example apps/backend/.env
#   cp .env.example apps/web/.env
# =============================================================================

# --- Backend (NestJS) -------------------------------------------------------
PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase). Pooled (PgBouncer, 6543) for the app; direct (5432) for migrations.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres"

# Pollar (onboarding-to-payment on Stellar - login + custodial wallets).
# The secret key (sec_testnet_...) is backend-ONLY: it enables wallet
# verification and Deferred-mode activation. Empty = verification skipped (dev).
POLLAR_API_URL="https://api.pollar.xyz"
POLLAR_SECRET_KEY=""

# Trustless Work (escrow). Testnet during development.
TRUSTLESS_WORK_API_URL="https://dev.api.trustlesswork.com"
TRUSTLESS_WORK_API_KEY=""

# Escrow on-chain: 'simulated' (no chain, full flow) or 'trustless_work'
# (requires TRUSTLESS_WORK_API_KEY + STELLAR_PLATFORM_SECRET on testnet).
ESCROW_MODE="simulated"

# Stellar
STELLAR_NETWORK="testnet"
USDC_ISSUER="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"
# Platform account (testnet, fund it with friendbot) that signs the Trustless
# Work XDRs: deploy/fund/approve/release/dispute/resolve.
STELLAR_PLATFORM_SECRET=""
STELLAR_PLATFORM_ADDRESS=""

# Payroll scheduler (cron for the tick that runs due funded payrolls)
PAYROLL_CRON="0 * * * *"
PAYROLL_SCHEDULER_ENABLED="true"

# Auth (BolPay session issued after login with Pollar)
JWT_SECRET="change-me-in-local-env"
JWT_EXPIRES_IN="1d"

# SMTP (transactional email: email verification + invitations).
# Empty = links are printed to the console instead of sent (local dev).
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=your@gmail.com,
# SMTP_PASS=<Google App Password> (requires 2-Step Verification enabled).
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="BolPay <your@gmail.com>"
# Public URL of the web client (used to build links in emails).
WEB_URL="http://localhost:5173"

# --- Web (Vite) - must be prefixed with VITE_ to be exposed to the client ----
VITE_API_URL="http://localhost:3000/api"
# Pollar publishable key (pub_testnet_... / pub_mainnet_...): safe on the client.
VITE_POLLAR_PUBLISHABLE_KEY="pub_testnet_xxxxxxxxxxxxxxxxxxxx"
# Client Stellar network: 'testnet' or 'mainnet'. Must match the backend
# (STELLAR_NETWORK) and the network of the Pollar publishable key.
VITE_STELLAR_NETWORK="testnet"

# --- Mobile (Flutter) ---------------------------------------------------------
# flutter run --dart-define API_URL=http://10.0.2.2:3000/api

# =============================================================================
# BolPay — root environment example. Copy per app to a local .env (never commit).
#   cp .env.example apps/backend/.env
#   cp .env.example apps/web/.env
# =============================================================================

# --- Backend (NestJS) -------------------------------------------------------
PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase). Pooled (PgBouncer, 6543) for the app; direct (5432) for migrations.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres"

# Pollar (onboarding-to-payment en Stellar — login + wallets custodiadas).
# El secret key (sec_testnet_...) es SOLO backend: habilita la verificación de
# wallets y la activación en modo Deferred. Vacío = verificación omitida (dev).
POLLAR_API_URL="https://api.pollar.xyz"
POLLAR_SECRET_KEY=""

# Trustless Work (escrow). Testnet during development.
TRUSTLESS_WORK_API_URL="https://dev.api.trustlesswork.com"
TRUSTLESS_WORK_API_KEY=""

# Escrow on-chain: 'simulated' (sin chain, flujo completo) o 'trustless_work'
# (requiere TRUSTLESS_WORK_API_KEY + STELLAR_PLATFORM_SECRET en testnet).
ESCROW_MODE="simulated"

# Stellar
STELLAR_NETWORK="testnet"
USDC_ISSUER="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"
# Cuenta plataforma (testnet, fondéala con friendbot) que firma los XDR de
# Trustless Work: deploy/fund/approve/release/dispute/resolve.
STELLAR_PLATFORM_SECRET=""
STELLAR_PLATFORM_ADDRESS=""

# Payroll scheduler (cron del tick que ejecuta planillas fondeadas vencidas)
PAYROLL_CRON="0 * * * *"
PAYROLL_SCHEDULER_ENABLED="true"

# Auth (sesión BolPay emitida tras el login con Pollar)
JWT_SECRET="change-me-in-local-env"
JWT_EXPIRES_IN="1d"

# --- Web (Vite) — must be prefixed with VITE_ to be exposed to the client ----
VITE_API_URL="http://localhost:3000/api"
# Publishable key de Pollar (pub_testnet_... / pub_mainnet_...): segura en el cliente.
VITE_POLLAR_PUBLISHABLE_KEY="pub_testnet_xxxxxxxxxxxxxxxxxxxx"

# --- Mobile (Flutter) ---------------------------------------------------------
# flutter run --dart-define API_URL=http://10.0.2.2:3000/api
